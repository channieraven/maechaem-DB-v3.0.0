# ---------------------------------------------------------------------------
# Mae Chaem Agroforestry DB — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore and must NEVER be committed to git.
# ---------------------------------------------------------------------------

# ---------------------------
# Neon Serverless Postgres
# ---------------------------
# Your Neon connection string. Enable PostGIS with:
#   CREATE EXTENSION IF NOT EXISTS postgis;
# in the Neon SQL editor.
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# ---------------------------
# Clerk Authentication
# ---------------------------
# Found in the Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URLs after sign-in / sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------------------------
# Clerk Webhook
# ---------------------------
# Found in the Clerk Dashboard → Webhooks → your endpoint → Signing Secret.
# Required by app/api/webhooks/clerk/route.ts to verify incoming events.
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------
# Cloudflare R2 — Drone COG
# ---------------------------
# HTTPS URL pointing to the Cloud Optimized GeoTIFF (COG) drone imagery file
# stored on Cloudflare R2 (or any publicly accessible object storage).
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev/drone/maechaem.tif
# Leave blank or omit to disable the drone imagery overlay on the map.
NEXT_PUBLIC_DRONE_COG_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev/drone/maechaem.tif
