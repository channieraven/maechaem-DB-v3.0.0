# ---------------------------------------------------------------------------
# Mae Chaem Agroforestry DB — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore and must NEVER be committed to git.
# ---------------------------------------------------------------------------

# ---------------------------
# Neon Serverless Postgres
# ---------------------------
# Your Neon connection string. Enable PostGIS with:
#   CREATE EXTENSION IF NOT EXISTS postgis;
# in the Neon SQL editor.
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# ---------------------------
# Clerk Authentication
# ---------------------------
# Found in the Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URLs after sign-in / sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------------------------
# Clerk Webhook
# ---------------------------
# Found in the Clerk Dashboard → Webhooks → your endpoint → Signing Secret.
# Required by app/api/webhooks/clerk/route.ts to verify incoming events.
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------
# Mapbox Tileset Overlay
# ---------------------------
# Public Mapbox access token (starts with pk.) — safe to expose to the browser.
# Found in the Mapbox account dashboard → Access Tokens.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_access_token_here
# The tileset ID to overlay on the satellite base map (format: username.tilesetname).
# Found in Mapbox Studio → Tilesets after uploading your GeoTIFF.
NEXT_PUBLIC_MAPBOX_TILESET_ID=username.tilesetname
